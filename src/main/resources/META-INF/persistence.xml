<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0"
             xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="btk" transaction-type="JTA">

        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- Oracle datasource registered in WildFly -->
        <jta-data-source>java:/BTKDS</jta-data-source>

        <class>com.btk.model.Utilisateur</class>
        <class>com.btk.model.ArchEmplacement</class>
        <class>com.btk.model.ArchDossier</class>
        <exclude-unlisted-classes>true</exclude-unlisted-classes>

        <properties>
            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.OracleDialect"/>
            <property name="hibernate.hbm2ddl.auto"  value="none"/>
            <property name="hibernate.show_sql"      value="true"/>
            <property name="hibernate.format_sql"    value="true"/>
        </properties>

    </persistence-unit>

</persistence>
